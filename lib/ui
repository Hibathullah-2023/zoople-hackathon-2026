            href="#">
            <span class="material-symbols-outlined">location_on</span>
            <span class="font-label-sm text-label-sm">Centers</span>
        </a>
    </nav>
    <script>
        let currentStep = 1;
        const totalSteps = 4;
        const nextBtn = document.getElementById('next-btn');
        const prevBtn = document.getElementById('prev-btn');
        const progressFill = document.getElementById('progress-fill');
        const stepCount = document.getElementById('step-count');
        const detailsTextarea = document.getElementById('incident-details');
        const reviewText = document.getElementById('review-text');

        function updateStep() {
            // Hide all steps
            for (let i = 1; i <= totalSteps; i++) {
                document.getElementById(`step-${i}`).classList.add('hidden');
            }
            // Show current step
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');

            // Update UI
            progressFill.style.width = `${(currentStep / totalSteps) * 100}%`;
            stepCount.textContent = `STEP ${currentStep}/${totalSteps}`;

            if (currentStep === 1) {
                prevBtn.classList.add('hidden');
            } else {
                prevBtn.classList.remove('hidden');
            }

            if (currentStep === totalSteps) {
                nextBtn.textContent = 'Submit Report';
                nextBtn.classList.remove('from-secondary', 'to-secondary-container');
                nextBtn.classList.add('from-tertiary', 'to-on-tertiary-container');
                reviewText.textContent = detailsTextarea.value || "No details provided...";
            } else {
                nextBtn.textContent = 'Next Step';
                nextBtn.classList.add('from-secondary', 'to-secondary-container');
                nextBtn.classList.remove('from-tertiary', 'to-on-tertiary-container');
            }
        }

        nextBtn.addEventListener('click', () => {
            if (currentStep < totalSteps) {
                currentStep++;
                updateStep();
            } else {
                // Handle Submit
                nextBtn.disabled = true;
                nextBtn.innerHTML = `<span class="material-symbols-outlined animate-spin">sync</span>`;
                setTimeout(() => {
                    alert("Report successfully submitted anonymously.");
                    window.location.reload();
                }, 2000);
            }
        });

        prevBtn.addEventListener('click', () => {
            if (currentStep > 1) {
                currentStep--;
                updateStep();
            }
        });

        // Anonymity Toggle Logic
        const toggleBtn = document.getElementById('toggle-anon');
        const toggleKnob = document.getElementById('toggle-knob');
        const shimmer = document.getElementById('shimmer-effect');
        const anonCard = document.getElementById('anonymity-card');
        const anonIcon = document.getElementById('anon-icon');
        let isAnon = true;

        toggleBtn.addEventListener('click', () => {
            isAnon = !isAnon;
            if (isAnon) {
                toggleBtn.classList.replace('bg-outline-variant', 'bg-secondary');
                toggleKnob.style.right = '4px';
                toggleKnob.style.left = 'auto';
                shimmer.classList.add('shimmer-active');
                anonCard.classList.add('border-secondary/20');
                anonIcon.style.fontVariationSettings = "'FILL' 1";
            } else {
                toggleBtn.classList.replace('bg-secondary', 'bg-outline-variant');
                toggleKnob.style.left = '4px';
                toggleKnob.style.right = 'auto';
                shimmer.classList.remove('shimmer-active');
                anonCard.classList.remove('border-secondary/20');
                anonIcon.style.fontVariationSettings = "'FILL' 0";
            }
        });
    </script>
</body>

